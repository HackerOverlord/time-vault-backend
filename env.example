# Time Vault — required environment variables
# Copy this file to .env for local development.
# On PythonAnywhere, set these under Web → Environment Variables.
# On Vercel, set NEXT_PUBLIC_API_URL under Project Settings → Environment Variables.

# ── Backend (PythonAnywhere) ──────────────────────────────────────────────────

# Flask secret key used to sign JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Required — the app will refuse to start if this is not set.
SECRET_KEY=

# Key used to XOR-encrypt legacy Memory content. Not used for V1 vault content.
# Generate with the same command as SECRET_KEY.
# Required — the app will refuse to start if this is not set.
ENCRYPTION_KEY=

# SQLite database path. Defaults to sqlite:///time_capsule.db (local directory).
# On PythonAnywhere: leave unset or set to an absolute path under /home/<username>/.
# DATABASE_URL=sqlite:////home/HackerOverlord/time_capsule.db

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────

# Full URL of the Flask backend, no trailing slash.
# Set this in Vercel Project Settings → Environment Variables.
# Required in production — without it the frontend calls localhost:5000.
NEXT_PUBLIC_API_URL=https://hackeroverlord.pythonanywhere.com
